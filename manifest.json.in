{
    "name": "xonotic.ratrad",
    "description": "Xonotic for Ubuntu Touch",
    "architecture": "$ENV{ARCH}",
    "title": "Xonotic",
    "hooks": {
        "xonotic": {
            "apparmor": "xonotic.apparmor",
            "desktop": "xonotic.desktop",
            "orientation": ["landscape", "inverted-landscape"]
        }
    },
    "version": "1.0.0",
    "maintainer": "ratrad",
    "framework": "$ENV{CLICK_FRAMEWORK}"
}
