{
    "name": "xonotic-touch.ratrad",
    "description": "Xonotic Touch — fast-paced arena FPS for touch devices",
    "architecture": "$ENV{ARCH}",
    "title": "Xonotic Touch",
    "hooks": {
        "xonotic-touch": {
            "apparmor": "xonotic.apparmor",
            "desktop": "xonotic.desktop",
            "orientation": ["landscape", "inverted-landscape"]
        }
    },
    "version": "1.1.0",
    "maintainer": "ratrad",
    "framework": "$ENV{CLICK_FRAMEWORK}"
}
