{
  "clickable_minimum_required": "8.0.0",
  "framework": "ubuntu-sdk-20.04",
  "builder": "custom",
  "build": "bash ${ROOT}/scripts/build.sh",
  "dependencies_target": [
    "libsdl2-dev",
    "libjpeg-dev",
    "zlib1g-dev",
    "libxmp-dev",
    "libgmp-dev",
    "zip",
    "autoconf",
    "automake",
    "libtool"
  ],
  "prebuild": "bash ${ROOT}/scripts/fetch-sources.sh code",
  "postbuild": "CLICKABLE_DEST=${INSTALL_DIR} bash ${ROOT}/scripts/install.sh",
  "skip_review": true,
  "scripts": {
    "build": "scripts/build.sh",
    "install": "scripts/install.sh"
  },
  "ignore": [
    "build",
    ".clickable",
    "engine/mediasource",
    "engine/netradiant"
  ]
}
